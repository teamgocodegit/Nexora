{
  "name": "nexora-server",
  "version": "1.0.0",
  "description": "Nexora Backend API",
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "puppeteer": "^24.43.1",
    "qrcode": "^1.5.4",
    "resend": "^6.16.0",
    "socket.io": "^4.7.5",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.12.5",
    "@types/qrcode": "^1.5.6",
    "prisma": "^5.10.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.4",
    "vitest": "^4.1.10"
  }
}
