generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SUB_ADMIN
}

enum HackathonStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum HackathonMode {
  PREDEFINED
  ON_SPOT
}

enum TeamStatus {
  REGISTERED
  CHECKED_IN
  ACTIVE
  SUBMITTED
  DISQUALIFIED
}

enum RegistrationStatus {
  PENDING_APPROVAL
  ACCEPTED
  WAITLISTED
  REJECTED
}

enum Channel {
  WHATSAPP
  SMS
  INTERNAL
}

enum MsgStatus {
  PENDING
  QUEUED
  SENT
  FAILED
}

enum RecipientType {
  ALL
  SELECTED
  SINGLE
}

enum CertType {
  PARTICIPATION
  WINNER
  RUNNER_UP
  SPECIAL
}

enum CertStatus {
  PENDING
  GENERATING
  GENERATED
  SENT
  FAILED
}

enum RoomStatus {
  AVAILABLE
  ACTIVE
  NEAR_CAPACITY
  FULL
  CLOSED
  ARCHIVED
}

enum CapacityOverrideStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum AutomationTriggerType {
  TIME_BASED
  EVENT_TRIGGERED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  QUEUED
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum RecipientDeliveryStatus {
  PENDING
  PROCESSING
  SENT
  RETRYING
  FAILED
  CANCELLED
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
}

enum SnapshotType {
  MANUAL
  PRE_EVENT
  EVENT_START
  MID_EVENT
  PRE_JUDGING
  PRE_RESULTS
  FINAL
  AUTOMATIC
}

enum SnapshotStatus {
  CREATING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?  @unique
  role      Role     @default(SUB_ADMIN)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  lastActivityAt  DateTime?
  assignedRooms   String?

  hackathons          Hackathon[]             @relation("HackathonCreator")
  archivedHackathons  Hackathon[]             @relation("HackathonArchiver")
  assignments         CoordinatorAssignment[]
  sentMessages        Message[]
  activityLogs        ActivityLog[]
  inviteLinks         InviteLink[]
  automations         Automation[]
  importBatches       ImportBatch[]
  emailCampaigns      EmailCampaign[]
  deletedTeams        Team[]                  @relation("TeamDeletion")
  deletedParticipants Participant[]            @relation("ParticipantDeletion")
  deletedRooms        Room[]                  @relation("RoomDeletion")
  snapshots           HackathonSnapshot[]
  capacityOverrides   CapacityOverride[]
}

model InviteLink {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String
  expiresAt   DateTime?
  usedAt      DateTime?
  usedBy      String?
  approved    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Hackathon {
  id          String          @id @default(cuid())
  name        String
  description String?
  venue       String?
  startDate   DateTime
  endDate     DateTime
  status      HackathonStatus @default(DRAFT)
  maxTeams    Int?
  logoUrl     String?
  mode        HackathonMode   @default(PREDEFINED)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  archivedAt      DateTime?
  archivedById    String?

  slug               String?    @unique
  registrationOpen   DateTime?
  registrationDeadline DateTime?
  minTeamSize        Int        @default(1)
  maxTeamSize        Int        @default(5)
  approvalRequired   Boolean    @default(true)
  waitlistEnabled    Boolean    @default(false)
  registrationFields Json?

  createdBy   User   @relation("HackathonCreator", fields: [createdById], references: [id])
  createdById String
  archivedBy  User?  @relation("HackathonArchiver", fields: [archivedById], references: [id])

  teams              Team[]
  rooms              Room[]
  registrations      Registration[]
  assignments        CoordinatorAssignment[]
  messages           Message[]
  certificates       Certificate[]
  activityLogs       ActivityLog[]
  importBatches      ImportBatch[]
  inviteLinks        InviteLink[]
  problemStatements  ProblemStatement[]
  scoringCriteria    ScoringCriteria[]
  automations        Automation[]
  milestones         EventMilestone[]
  emailCampaigns     EmailCampaign[]
  snapshots          HackathonSnapshot[]
  capacityOverrides  CapacityOverride[]
}

model Registration {
  id              String             @id @default(cuid())
  registrationId  String             @unique
  status          RegistrationStatus @default(PENDING_APPROVAL)
  teamName        String
  college         String?
  city            String?
  leaderName      String
  leaderEmail     String
  leaderPhone     String?
  memberData      Json?
  gitHubUrl       String?
  linkedInUrl     String?
  portfolioUrl    String?
  dietary         String?
  accessibility   String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String
}

model Room {
  id        String     @id @default(cuid())
  name      String
  code      String?
  description String?
  building  String?
  floor     String?
  capacityTeams  Int?
  capacityPeople Int?
  capacity  Int        @default(30)
  notes     String?
  sortOrder Int        @default(0)
  status    RoomStatus @default(AVAILABLE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  deletedAt       DateTime?
  deletedById     String?
  deletionReason  String?

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  deletedBy User? @relation("RoomDeletion", fields: [deletedById], references: [id])
  teams     Team[]
  capacityOverrides CapacityOverride[]

  @@unique([hackathonId, name])
}

model Automation {
  id              String               @id @default(cuid())
  name            String
  description     String?
  triggerType     AutomationTriggerType
  triggerConfig   Json?
  recipientGroup  String?
  template        String?
  templateSubject String?
  status          AutomationStatus     @default(ACTIVE)
  scheduledTime   DateTime?
  lastExecutedAt  DateTime?
  createdAt       DateTime             @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  createdBy   User  @relation(fields: [createdById], references: [id])
  createdById String
}

model EmailCampaign {
  id             String         @id @default(cuid())
  name           String
  subject        String
  messageBody    String
  bodyFormat     String         @default("html")
  audienceType   String
  audienceFilter Json?
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  totalRecipients Int           @default(0)
  pendingCount   Int            @default(0)
  processingCount Int           @default(0)
  sentCount      Int            @default(0)
  failedCount    Int            @default(0)
  cancelledCount Int            @default(0)
  failureReason  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  createdBy   User  @relation(fields: [createdById], references: [id])
  createdById String

  recipients EmailRecipient[]

  @@index([hackathonId, status])
  @@index([scheduledAt, status])
}

model EmailRecipient {
  id                   String                 @id @default(cuid())
  email                String
  recipientName        String?
  personalizedSubject  String?
  status               RecipientDeliveryStatus @default(PENDING)
  attemptCount         Int                    @default(0)
  nextRetryAt          DateTime?
  providerMessageId    String?
  lastError            String?
  sentAt               DateTime?
  failedAt             DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String

  participantId String?
  teamId        String?

  @@unique([campaignId, email])
  @@index([status, nextRetryAt])
  @@index([campaignId, status])
}

model EventMilestone {
  id          String   @id @default(cuid())
  title       String
  time        DateTime
  description String?

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  createdAt DateTime @default(now())
}

model CoordinatorAssignment {
  id         String   @id @default(cuid())
  assignedAt DateTime @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  teams Team[] @relation("CoordinatorTeams")

  @@unique([hackathonId, userId])
}

model ProblemStatement {
  id          String    @id @default(cuid())
  title       String
  description String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String
  teams       Team[]    @relation("TeamProblem")
  createdAt   DateTime  @default(now())
}

model Team {
  id             String     @id @default(cuid())
  teamId         String?    @unique
  qrToken        String?    @unique
  name           String
  status         TeamStatus @default(REGISTERED)
  room           String?
  tableNumber    String?
  projectName    String?
  projectUrl     String?
  notes          String?
  leaderPhone    String?
  checkInTime    DateTime?
  checkInBy      String?
  submissionTime DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  deletedAt       DateTime?
  deletedById     String?
  deletionReason  String?

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  coordinator   CoordinatorAssignment? @relation("CoordinatorTeams", fields: [coordinatorId], references: [id])
  coordinatorId String?

  problemStatement   ProblemStatement? @relation("TeamProblem", fields: [problemStatementId], references: [id])
  problemStatementId String?

  roomId String?

  roomRef Room? @relation(fields: [roomId], references: [id])
  capacityOverrides CapacityOverride[]

  deletedBy   User? @relation("TeamDeletion", fields: [deletedById], references: [id])
  participants      Participant[]
  messageRecipients MessageRecipient[]
  certificates      Certificate[]
  scores            Score[]

  @@unique([hackathonId, name])
  @@index([roomId])
}

model Participant {
  id       String  @id @default(cuid())
  name     String
  email    String?
  phone    String?
  isLeader Boolean @default(false)

  deletedAt       DateTime?
  deletedById     String?
  deletionReason  String?

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String

  deletedBy User? @relation("ParticipantDeletion", fields: [deletedById], references: [id])
}

model ScoringCriteria {
  id          String  @id @default(cuid())
  name        String
  description String?
  maxScore    Int     @default(10)
  weight      Float   @default(1.0)
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  scores      Score[]
}

model Score {
  id         String          @id @default(cuid())
  value      Float
  judgeId    String
  team       Team            @relation(fields: [teamId], references: [id])
  teamId     String
  criteria   ScoringCriteria @relation(fields: [criteriaId], references: [id])
  criteriaId String
  createdAt  DateTime        @default(now())

  @@unique([teamId, criteriaId, judgeId])
}

model Message {
  id            String        @id @default(cuid())
  content       String
  channel       Channel
  status        MsgStatus     @default(PENDING)
  recipientType RecipientType
  sentAt        DateTime      @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId String

  sentBy   User   @relation(fields: [sentById], references: [id])
  sentById String

  recipients MessageRecipient[]
}

model MessageRecipient {
  id     String    @id @default(cuid())
  status MsgStatus @default(PENDING)
  sentAt DateTime?
  error  String?

  message   Message @relation(fields: [messageId], references: [id])
  messageId String

  team   Team   @relation(fields: [teamId], references: [id])
  teamId String
}

model Certificate {
  id              String     @id @default(cuid())
  participantName String
  email           String
  type            CertType   @default(PARTICIPATION)
  status          CertStatus @default(PENDING)
  pdfUrl          String?
  templateUrl     String?
  errorMessage    String?
  generatedAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime   @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId String

  team   Team   @relation(fields: [teamId], references: [id])
  teamId String
}

model ImportBatch {
  id                  String   @id @default(cuid())
  originalFileName    String
  fileType            String
  selectedSheetName   String?
  sourceType          String   @default("UPLOAD")
  fileFingerprint     String?
  totalRows           Int      @default(0)
  validRows           Int      @default(0)
  warningRows         Int      @default(0)
  errorRows           Int      @default(0)
  importedTeams       Int      @default(0)
  importedParticipants Int     @default(0)
  skippedRows         Int      @default(0)
  status              String   @default("UPLOADED")
  failureReason       String?
  mappingConfig       Json?
  importSummary       Json?
  createdAt           DateTime @default(now())
  completedAt         DateTime?

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  createdBy   User  @relation(fields: [createdById], references: [id])
  createdById String

  @@index([hackathonId, status])
  @@index([createdById])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  teamId    String?
  teamName  String?
  entityType String?
  entityId   String?
  timestamp DateTime @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId String

  actor   User   @relation(fields: [actorId], references: [id])
  actorId String
}

model HackathonSnapshot {
  id            String         @id @default(cuid())
  type          SnapshotType   @default(MANUAL)
  status        SnapshotStatus @default(CREATING)
  schemaVersion Int            @default(1)
  checksum      String?
  data          Json?
  recordCounts  Json?
  size          Int?
  failureReason String?
  createdAt     DateTime       @default(now())
  completedAt   DateTime?

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([hackathonId, type])
  @@index([hackathonId, createdAt])
}

model CapacityOverride {
  id                String                @id @default(cuid())
  reason            String
  previousOccupancyTeams   Int
  previousOccupancyPeople  Int
  projectedOccupancyTeams  Int
  projectedOccupancyPeople Int
  status            CapacityOverrideStatus @default(APPROVED)
  createdAt         DateTime              @default(now())

  room   Room   @relation(fields: [roomId], references: [id])
  roomId String

  team   Team?  @relation(fields: [teamId], references: [id])
  teamId String?

  actor   User   @relation(fields: [actorId], references: [id])
  actorId String

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId String

  @@index([roomId])
  @@index([hackathonId])
}

model BackupMetadata {
  id                    String    @id @default("singleton")
  backupProvider        String?
  lastVerifiedBackup    DateTime?
  lastRestoreTest       DateTime?
  recoveryDocsUrl       String?
  recoveryPointObjective Int?
  recoveryTimeObjective  Int?
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
}
