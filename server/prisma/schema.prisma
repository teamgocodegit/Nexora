generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?  @unique
  role      Role     @default(COORDINATOR)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  lastActivityAt DateTime?
  assignedRooms String?

  otpCodes     OtpCode[]
  hackathons   Hackathon[]             @relation("HackathonCreator")
  assignments  CoordinatorAssignment[]
  sentMessages Message[]
  activityLogs ActivityLog[]
  inviteLinks  InviteLink[]
}

model OtpCode {
  id        String   @id @default(cuid())
  code      String
  contact   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id])
  userId String?
}

model InviteLink {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String
  expiresAt   DateTime?
  usedAt      DateTime?
  usedBy      String?
  approved    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Hackathon {
  id          String          @id @default(cuid())
  name        String
  description String?
  venue       String?
  startDate   DateTime
  endDate     DateTime
  status      HackathonStatus @default(DRAFT)
  maxTeams    Int?
  logoUrl     String?
  mode        HackathonMode   @default(PREDEFINED)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy   User   @relation("HackathonCreator", fields: [createdById], references: [id])
  createdById String

  teams        Team[]
  assignments  CoordinatorAssignment[]
  messages     Message[]
  certificates Certificate[]
  activityLogs ActivityLog[]
  inviteLinks  InviteLink[]
  problemStatements ProblemStatement[]
  scoringCriteria    ScoringCriteria[]
}

model CoordinatorAssignment {
  id         String   @id @default(cuid())
  assignedAt DateTime @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  teams Team[] @relation("CoordinatorTeams")

  @@unique([hackathonId, userId])
}

model ProblemStatement {
  id          String    @id @default(cuid())
  title       String
  description String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String
  teams       Team[]    @relation("TeamProblem")
  createdAt   DateTime  @default(now())
}

model Team {
  id             String     @id @default(cuid())
  name           String
  status         TeamStatus @default(REGISTERED)
  room           String?
  tableNumber    String?
  projectName    String?
  projectUrl     String?
  notes          String?
  leaderPhone    String?
  checkInTime    DateTime?
  submissionTime DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  coordinator   CoordinatorAssignment? @relation("CoordinatorTeams", fields: [coordinatorId], references: [id])
  coordinatorId String?

  problemStatement   ProblemStatement? @relation("TeamProblem", fields: [problemStatementId], references: [id])
  problemStatementId String?

  participants      Participant[]
  messageRecipients MessageRecipient[]
  certificates      Certificate[]
  scores            Score[]

  @@unique([hackathonId, name])
}

model Participant {
  id       String  @id @default(cuid())
  name     String
  email    String?
  phone    String?
  isLeader Boolean @default(false)

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
}

model ScoringCriteria {
  id          String  @id @default(cuid())
  name        String
  description String?
  maxScore    Int     @default(10)
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  scores      Score[]
}

model Score {
  id         String          @id @default(cuid())
  value      Float
  judgeId    String
  team       Team            @relation(fields: [teamId], references: [id])
  teamId     String
  criteria   ScoringCriteria @relation(fields: [criteriaId], references: [id])
  criteriaId String
  createdAt  DateTime        @default(now())

  @@unique([teamId, criteriaId, judgeId])
}

model Message {
  id            String        @id @default(cuid())
  content       String
  channel       Channel
  status        MsgStatus     @default(PENDING)
  recipientType RecipientType
  sentAt        DateTime      @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId String

  sentBy   User   @relation(fields: [sentById], references: [id])
  sentById String

  recipients MessageRecipient[]
}

model MessageRecipient {
  id     String    @id @default(cuid())
  status MsgStatus @default(PENDING)
  sentAt DateTime?
  error  String?

  message   Message @relation(fields: [messageId], references: [id])
  messageId String

  team   Team   @relation(fields: [teamId], references: [id])
  teamId String
}

model Certificate {
  id              String     @id @default(cuid())
  participantName String
  email           String
  type            CertType   @default(PARTICIPATION)
  status          CertStatus @default(PENDING)
  pdfUrl          String?
  templateUrl     String?
  errorMessage    String?
  generatedAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime   @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId String

  team   Team   @relation(fields: [teamId], references: [id])
  teamId String
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  teamId    String?
  teamName  String?
  timestamp DateTime @default(now())

  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId String

  actor   User   @relation(fields: [actorId], references: [id])
  actorId String
}

enum Role {
  SUPER_ADMIN
  SUB_ADMIN
  COORDINATOR
}

enum HackathonStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum HackathonMode {
  PREDEFINED
  ON_SPOT
}

enum TeamStatus {
  REGISTERED
  CHECKED_IN
  ACTIVE
  SUBMITTED
  DISQUALIFIED
}

enum Channel {
  WHATSAPP
  SMS
  INTERNAL
}

enum MsgStatus {
  PENDING
  QUEUED
  SENT
  FAILED
}

enum RecipientType {
  ALL
  SELECTED
  SINGLE
}

enum CertType {
  PARTICIPATION
  WINNER
  RUNNER_UP
  SPECIAL
}

enum CertStatus {
  PENDING
  GENERATING
  GENERATED
  SENT
  FAILED
}
